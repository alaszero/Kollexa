# Kollexa - Configuración de Entorno
# Copiar a .env y ajustar valores

# Flask
FLASK_APP=wsgi.py
FLASK_ENV=development
SECRET_KEY=cambiar-por-clave-segura-generada

# Base de datos
# SQLite (desarrollo/local)
DATABASE_URI=sqlite:///kollexa.db
# PostgreSQL (producción futura)
# DATABASE_URI=postgresql://user:pass@localhost:5432/kollexa

# JWT
JWT_SECRET_KEY=cambiar-por-otra-clave-segura
JWT_ACCESS_TOKEN_EXPIRES=3600

# Caché
CACHE_TYPE=SimpleCache
# CACHE_TYPE=RedisCache
# CACHE_REDIS_URL=redis://localhost:6379/0

# Aplicación
APP_NAME=Kollexa
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_EMAIL=admin@kollexa.local
